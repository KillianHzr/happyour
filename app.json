{
  "expo": {
    "name": "HappyOur",
    "slug": "HappyOur",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jeanmiduntm.HappyOur",
      "icon": "./assets/icon.png",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.happyour.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "happyour",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'app a besoin d'accéder à tes photos pour changer ton profil."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'app a besoin de la caméra pour capturer des moments.",
          "microphonePermission": "L'app a besoin du micro pour enregistrer des vidéos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000000"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65222b8e-774d-4367-b67b-4f7c9799cac1"
      }
    },
    "owner": "axel_genin"
  }
}
